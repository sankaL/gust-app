{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.railway"
  },
  "deploy": {
    "startCommand": "sh -lc 'serve -s dist -l tcp://0.0.0.0:${PORT:-4173}'",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 5
  }
}

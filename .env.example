# Gust environment reference.
# Copy this to `.env` for local work. Use `.env.prod` as a production-oriented template.
# Google OAuth client secrets are configured in Supabase, not in Gust app env files.

# Backend startup essentials
APP_ENV=development
GUST_DEV_MODE=true
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:54322/postgres
REQUIRED_ALEMBIC_REVISION=0004_phase4_reminders_retention
RUN_STARTUP_CHECKS=true
LOG_LEVEL=INFO

# Auth and app URLs
# Local Docker runs override these values with the active ports and local Supabase anon key
# in `.dev-runtime/runtime.env`.
FRONTEND_APP_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:8000
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# Session and retention settings
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=
CAPTURE_RETENTION_DAYS=7

# Transcription provider: Mistral
MISTRAL_API_URL=https://api.mistral.ai/v1/audio/transcriptions
MISTRAL_API_KEY=
MISTRAL_TRANSCRIPTION_MODEL=voxtral-mini-latest
TRANSCRIPTION_TIMEOUT_SECONDS=20

# Extraction provider: OpenRouter
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_API_KEY=
OPENROUTER_EXTRACTION_MODEL=google/gemini-3-flash-preview
EXTRACTION_TIMEOUT_SECONDS=20

# Reminder delivery: Resend
RESEND_API_URL=https://api.resend.com/emails
RESEND_API_KEY=
RESEND_FROM_EMAIL=
INTERNAL_JOB_SHARED_SECRET=
REMINDER_BATCH_SIZE=50
REMINDER_CLAIM_TIMEOUT_SECONDS=600
REMINDER_REQUEST_TIMEOUT_SECONDS=10

# Frontend build-time env
VITE_GUST_DEV_MODE=true
VITE_API_BASE_URL=http://localhost:8000
